{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py collectstatic --noinput && gunicorn gamerid.wsgi --bind 0.0.0.0:$PORT --workers 2",
    "preDeployCommand": "python manage.py migrate --noinput && python manage.py ensure_admin",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
