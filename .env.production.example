# ====================================================================
#  PRODUCCIÓN — copiar a .env EN EL SERVIDOR y ajustar el dominio.
# ====================================================================

# Genera una clave nueva con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=reemplaza-por-una-clave-larga-y-secreta
DEBUG=False

# Reemplaza por tu dominio real (sin http://). Separados por coma.
ALLOWED_HOSTS=tudominio.com,www.tudominio.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Oculta la barra "PROTOTIPO · DEMO" para los usuarios reales.
SHOW_DEMO_NAV=False

# --- Base de datos ---
# Vacío = SQLite (archivo db.sqlite3). Debe estar en DISCO PERSISTENTE.
# Solo descomenta si algún día migras a Postgres:
# DATABASE_URL=postgres://usuario:password@localhost:5432/gamerid

# --- HTTPS ---
# Actívalos SOLO cuando el dominio ya tenga certificado (si no, romperías
# un demo servido por http). Detrás de Nginx/Caddy que reenvía X-Forwarded-Proto.
# SECURE_SSL_REDIRECT=True
# COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_SUBDOMAINS=True

# --- Correo (apagado) ---
# Completar con el SMTP del cliente cuando lo entreguen:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.proveedor.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=usuario
# EMAIL_HOST_PASSWORD=password
# DEFAULT_FROM_EMAIL=GamerID <no-reply@gamerid.gg>
# SEND_STATUS_EMAILS=True
