# Copia este archivo a .env y ajusta los valores.

# --- General ---
SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SHOW_DEMO_NAV=True

# --- Base de datos ---
# Dev: deja esto comentado y usa SQLite automáticamente.
# Prod: descomenta y apunta a tu Postgres. ¡Eso es todo lo que cambia!
# DATABASE_URL=postgres://gamerid:password@localhost:5432/gamerid

# --- Correo (apagado por defecto: imprime en consola) ---
# Para activar el SMTP del cliente, completa estos valores:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.tu-proveedor.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=usuario
# EMAIL_HOST_PASSWORD=password
# DEFAULT_FROM_EMAIL=GamerID <no-reply@gamerid.gg>
# SEND_STATUS_EMAILS=True
